<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dhf.hrsys.dao.EmployeeDao">
    <resultMap type="com.hongfang.csp.system.entity.Employee" id="EmpAndDep">
        <id property="id" column="id"/>
        <result property="number" column="number"/>
        <result property="name" column="name"/>
        <result property="gender" column="gender"/>
        <result property="age" column="age"/>
        <association property="dep" javaType="com.hongfang.csp.system.entity.Department">
            <id property="id" column="dep_id"/>
            <result property="number" column="number"/>
            <result property="name" column="depName"/>
        </association>
    </resultMap>
    <!-- 取得全部員工清單 -->
    <select id="search" resultMap="EmpAndDep">
        select e.*, d.name as depName from
        employee as e left join department as d on
        e.dep_id = d.id
        <where>
            <if test="number != null and number != 0">
                and e.number = #{number}
            </if>
            <if test="name != null and name != ''">
                and e.name like '%' || #{name} || '%'
            </if>
            <if test="gender != null and gender != ''">
                and e.gender = #{gender}
            </if>
            <if test="age != null and age != 0">
                and e.age = #{age}
            </if>
            <if test="dep != null and dep.id != null and dep.id != 0">
                and e.dep_id = #{dep.id}
            </if>
        </where>
        order by e.id
    </select>
    
    <!-- 新增員工 -->
    <insert id="add" parameterType="com.hongfang.csp.system.entity.Employee">
        <selectKey keyProperty="id" resultType="int" order="BEFORE">
            select coalesce(max(id), 0) + 1 from employee
        </selectKey>
        insert into employee (id, number, name, gender, age, dep_id)
        values (#{id}, #{number}, #{name}, #{gender}, #{age}, #{dep.id})
    </insert>
    
    <!-- 依識別碼查詢員工 -->
    <select id="searchById" resultMap="EmpAndDep" parameterType="int">
        select e.*, d.name as depName from
        employee as e left join department as d on
        e.dep_id = d.id
        where e.id = #{id}
    </select>
    
    <!-- 更新員工資料 -->
    <update id="update" parameterType="com.hongfang.csp.system.entity.Employee">
        update employee
        set number = #{number},
            name = #{name},
            gender = #{gender},
            age = #{age},
            dep_id = #{dep.id}
        where id = #{id}
    </update>

    <!-- 刪除員工 -->
    <delete id="delete" parameterType="int">
        delete from employee where id = #{id}
    </delete>
</mapper>
