@startuml
title Madaga + Spring AI 架構整合圖

package "madaga.backend" {
  class MadagaController {
    +chat(request: ChatRequest): ChatResponse
  }

  class MadagaService {
    +handleChat(request: ChatRequest): ChatResponse
  }

  interface AIModelAdapter {
    +generate(request: ModelRequest): ModelResponse
    +embed(text: String): float[]
  }

  class OllamaAdapter {
    +generate(request: ModelRequest): ModelResponse
    +embed(text: String): float[]
  }

  class RAGService {
    +answer(query: String): String
  }

  class VectorStoreManager {
    +store(Embedding): void
    +search(query: String): List<Document>
  }

  MadagaController --> MadagaService
  MadagaService --> AIModelAdapter
  AIModelAdapter <|-- OllamaAdapter
  MadagaService --> RAGService
  RAGService --> VectorStoreManager
}

package "Spring AI Core" {
  interface Model
  interface ChatModel extends Model
  interface EmbeddingModel extends Model

  class ChatClient {
    +chat(request: ChatRequest): ChatResponse
  }

  class EmbeddingClient {
    +embed(text: String): EmbeddingResponse
  }

  ChatClient --> ChatModel
  EmbeddingClient --> EmbeddingModel
}

package "Spring AI Vector" {
  interface VectorStore {
    +add(Embedding): void
    +similaritySearch(query: String): List<Document>
  }

  class VectorStoreRetriever {
    +retrieve(query: String): List<Document>
  }

  VectorStoreRetriever --> VectorStore
}

package "Spring AI RAG" {
  class RetrievalAugmentedGenerationService {
    +answer(query: String): String
  }

  RetrievalAugmentedGenerationService --> ChatClient
  RetrievalAugmentedGenerationService --> VectorStoreRetriever
}

' ==== 整合連結 ====
MadagaService --> ChatClient : uses
OllamaAdapter --> ChatModel : delegates
OllamaAdapter --> EmbeddingModel : delegates
VectorStoreManager --> VectorStore : uses
RAGService --> RetrievalAugmentedGenerationService : wraps
@enduml